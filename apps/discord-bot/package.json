{
  "name": "@repo/discord-bot",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify --env production",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "lint": "biome lint src/",
    "lint:fix": "biome check --fix src/",
    "format": "biome format --write src/",
    "check": "biome check src/",
    "ngrok": "ngrok http 8787",
    "deploy:commands": "nlx tsx src/discord/register.ts"
  },
  "dependencies": {
    "discord-api-types": "^0.38.46",
    "discord-interactions": "^4.4.0",
    "hono": "^4.12.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.0",
    "@cloudflare/workers-types": "^4.20260313.1",
    "@types/node": "^24.1.0",
    "dotenv": "^17.4.2",
    "wrangler": "^4.73.0"
  },
  "engines": {
    "node": "24.x"
  }
}
