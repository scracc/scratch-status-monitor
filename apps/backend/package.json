{
  "name": "@scracc/ssm-backend",
  "type": "module",
  "scripts": {
    "db:start": "nlx supabase start",
    "db:stop": "nlx supabase stop",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify --env production",
    "cron": "tsx .scripts/auto-cron.ts",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "lint": "biome lint src/",
    "lint:fix": "biome check --fix src/",
    "format": "biome format --write src/",
    "check": "biome check src/"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.3.0",
    "@scalar/hono-api-reference": "^0.10.3",
    "@scracc/ssm-configs": "workspace:*",
    "@scracc/ssm-types": "workspace:*",
    "@supabase/supabase-js": "^2.99.1",
    "hono": "^4.12.7",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.0",
    "@cloudflare/workers-types": "^4.20260313.1",
    "@types/node": "^24.1.0",
    "supabase": "^2.78.1",
    "tsx": "^4.21.0",
    "wrangler": "^4.73.0"
  },
  "engines": {
    "node": "24.x"
  }
}
