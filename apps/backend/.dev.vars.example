# Cloudflare Workers ローカル開発環境変数
# このファイルを .dev.vars にコピーして使用してください
# .dev.vars はGitにコミットしないでください

# 環境モード
# development: テストルートが有効
# production: テストルートが無効
ENVIRONMENT=development

# API Bearer 認証トークン（後方互換 / ブートストラップ用）
# 管理トークンを最初に作成するための admin トークンとして使えます
API_TOKEN=your-secret-token-here

# Drizzle(Postgres) 接続設定
# Supabase の Connection string (URI) を設定してください
DATABASE_URL=