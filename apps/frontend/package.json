{
  "name": "@scracc/ssm-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "?dev": "開発サーバーを起動",
    "dev": "vite dev --port 3000",
    "?build": "アプリをビルド",
    "build": "vite build && cpy instrument.server.mjs .output/server/",
    "?preview": "ビルドされたアプリをプレビュー",
    "preview": "vite preview --port 3000",
    "?start": "ビルドされたアプリを起動",
    "start": "node .output/server/index.mjs",
    "?test": "Vitestを実行",
    "test": "vitest run",
    "?format": "コードのスタイルを自動で整形",
    "format": "biome format",
    "?lint": "コードのスタイルチェックを実行",
    "lint": "biome lint",
    "?check": "コードの型チェックとスタイルチェックを実行",
    "check": "biome check",
    "?v:dev": "Vercel向けの開発サーバー",
    "v:dev": "nlx vercel dev",
    "?v:build": "Vercel向けのビルド",
    "v:build": "nlx vercel build",
    "?v:dep:prev": "プレビュー環境向けのビルドとデプロイ",
    "v:dep:prev": "nlx vercel build --target preview && nlx vercel deploy --prebuilt",
    "?o:v:dep:prev": "プレビュー環境向けのビルド済みアプリをVercelにデプロイします",
    "o:v:dep:prev": "nlx vercel deploy --prebuilt",
    "?v:dep:prod": "プロダクション環境向けのビルドとデプロイ",
    "v:dep:prod": "nlx vercel build --target production && nlx vercel deploy --prebuilt --prod",
    "?o:v:dep:prod": "プロダクション環境向けのビルド済みアプリをVercelにデプロイします",
    "o:v:dep:prod": "nlx vercel deploy --prebuilt --prod",
    "?machine-translate": "機械翻訳を実行",
    "machine-translate": "inlang machine translate --project project.inlang"
  },
